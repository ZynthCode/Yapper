<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <OutputPath>bin\$(Configuration)\Mods\yapper</OutputPath>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
  </PropertyGroup>

  <PropertyGroup>
    <VINTAGE_STORY Condition="'$(VINTAGE_STORY)' == ''">$(USERPROFILE)\AppData\Roaming\Vintagestory</VINTAGE_STORY>
    <VINTAGE_STORY_DATA Condition="'$(VINTAGE_STORY_DATA)' == ''">$(USERPROFILE)\AppData\Roaming\VintagestoryData</VINTAGE_STORY_DATA>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="VintagestoryAPI">
      <HintPath>$(VINTAGE_STORY)/VintagestoryAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Include="modinfo.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
